# Auth0 server-side session configuration for Savant.
# The current Auth0 application is configured only for https://savantrepo.com.
# If you want to test a different origin locally, add its callback/logout URLs in Auth0 first.

APP_BASE_URL=https://savantrepo.com
AUTH0_DOMAIN=dev-uzaxp03ophsygo6g.us.auth0.com
AUTH0_CLIENT_ID=SIITci8080F0O0aNSoVEjAaDqTpsO7q5
AUTH0_CLIENT_SECRET=<AUTH0_CLIENT_SECRET>
# 64 hex characters generated with: openssl rand -hex 32
AUTH0_SECRET=<AUTH0_SECRET_HEX_64_CHARS>

# Required for durable production onboarding, tenant provisioning, and webhook-backed
# Auth0/Stripe correlation. Apply db/schema/0001_control_plane.sql and
# db/schema/0002_onboarding.sql and db/schema/0003_multitenancy.sql to this database.
DATABASE_URL=<DATABASE_URL>

# Optional local billing return URL override for Stripe Checkout.
# Leave unset in production to fall back to APP_BASE_URL / Vercel metadata.
NEXT_PUBLIC_APP_URL=<NEXT_PUBLIC_APP_URL>

# Optional local onboarding sandbox for development-only click-through testing.
# When enabled, Savant simulates Auth0 identity and hosted checkout so you can
# test the onboarding flow locally without live providers.
ONBOARDING_DEV_SANDBOX=0
# Optional overrides for the synthetic sandbox identity.
ONBOARDING_SANDBOX_SUBJECT=dev-sandbox|local-user
ONBOARDING_SANDBOX_EMAIL=local@savant.dev
ONBOARDING_SANDBOX_NAME=Local Sandbox User
# Optional sandbox checkout result: success | cancel | fail
ONBOARDING_DEV_SANDBOX_OUTCOME=success

# Stripe billing configuration for apps/web/.env.local or your deployment env.
# Savant uses a single "Savant Seat" product for every customer.
# Hosted checkout works with just STRIPE_SECRET_KEY; price ids are optional.
# The seat pricing is $1 / seat / month and $10 / seat / year.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=<NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY>
STRIPE_SECRET_KEY=<STRIPE_SECRET_KEY>
STRIPE_PRICE_ID_MONTHLY=<STRIPE_PRICE_ID_MONTHLY>
STRIPE_PRICE_ID_YEARLY=<STRIPE_PRICE_ID_YEARLY>
STRIPE_WEBHOOK_SECRET=<STRIPE_WEBHOOK_SECRET>
