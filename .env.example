# Auth0 server-side session configuration for Savant.
# The current Auth0 application is configured only for https://savantrepo.com.
# If you want to test a different origin locally, add its callback/logout URLs in Auth0 first.

# Optional but recommended for a single stable production domain.
# If omitted, Savant can fall back to NEXT_PUBLIC_APP_URL, VERCEL_PROJECT_PRODUCTION_URL,
# VERCEL_URL, or the request host at runtime.
APP_BASE_URL=https://savantrepo.com
AUTH0_DOMAIN=dev-uzaxp03ophsygo6g.us.auth0.com
AUTH0_CLIENT_ID=SIITci8080F0O0aNSoVEjAaDqTpsO7q5
# Optional public aliases supported by the deployment diagnostics and runtime normalization.
# Useful when your hosting platform only exposes these values to the frontend bundle by default.
# NEXT_PUBLIC_AUTH0_DOMAIN=dev-uzaxp03ophsygo6g.us.auth0.com
# NEXT_PUBLIC_AUTH0_CLIENT_ID=SIITci8080F0O0aNSoVEjAaDqTpsO7q5
# NEXT_PUBLIC_AUTH0_ISSUER_BASE_URL=https://dev-uzaxp03ophsygo6g.us.auth0.com
AUTH0_CLIENT_SECRET=<AUTH0_CLIENT_SECRET>
# 64 hex characters generated with: openssl rand -hex 32
AUTH0_SECRET=<AUTH0_SECRET_HEX_64_CHARS>

# Required for durable production onboarding, tenant provisioning, webhook-backed
# Auth0/Stripe correlation, and BYO-AI connection persistence. Apply
# db/schema/0001_control_plane.sql, db/schema/0002_onboarding.sql,
# db/schema/0003_multitenancy.sql, and db/schema/0004_ai_connections.sql
# to this database.
DATABASE_URL=<DATABASE_URL>

# GitHub-first repository write configuration for the secure MVP.
# Store the ENV VAR NAME in git_provider_connections.credentials_ref, not the token itself.
# Example row: credentials_ref = 'GITHUB_WRITE_TOKEN'
# Use a GitHub access token that can create repositories and commit content for the target org.
GITHUB_WRITE_TOKEN=<GITHUB_WRITE_TOKEN>
# Optional extra per-tenant/provider tokens can use distinct env var names referenced from the DB.
# GITHUB_WRITE_TOKEN_FINANCE=<GITHUB_WRITE_TOKEN_FINANCE>

# 32-byte secret used to encrypt tenant BYO-AI API keys before they are written
# into Savant's server-side encrypted vault table. Accepts either 64 hex chars
# or standard base64 for 32 raw bytes.
# Generate with: openssl rand -base64 32
AI_CONNECTION_ENCRYPTION_KEY=<AI_CONNECTION_ENCRYPTION_KEY>

# Optional public app origin override for onboarding + hosted checkout.
# Savant also uses this as a fallback Auth0 app base URL when APP_BASE_URL is unset.
NEXT_PUBLIC_APP_URL=<NEXT_PUBLIC_APP_URL>

# Optional local onboarding sandbox for development-only click-through testing.
# When enabled, Savant simulates Auth0 identity and hosted checkout so you can
# test the onboarding flow locally without live providers.
ONBOARDING_DEV_SANDBOX=0
# Optional overrides for the synthetic sandbox identity.
ONBOARDING_SANDBOX_SUBJECT=dev-sandbox|local-user
ONBOARDING_SANDBOX_EMAIL=local@savant.dev
ONBOARDING_SANDBOX_NAME=Local Sandbox User
# Optional sandbox checkout result: success | cancel | fail
ONBOARDING_DEV_SANDBOX_OUTCOME=success

# Stripe billing configuration for apps/web/.env.local or your deployment env.
# Savant uses a single "Savant Seat" product for every customer.
# Hosted checkout works with just STRIPE_SECRET_KEY; price ids are optional.
# For the fastest unblock, configure a native Stripe pricing table and embed it
# in onboarding with NEXT_PUBLIC_STRIPE_PRICING_TABLE_ID plus the publishable key.
# Set the pricing table's success URL to:
#   https://savantrepo.com/onboarding/success?session_id={CHECKOUT_SESSION_ID}
# and the cancel URL to:
#   https://savantrepo.com/onboarding?cancelled=1
# The seat pricing is $1 / seat / month and $10 / seat / year.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=<NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY>
NEXT_PUBLIC_STRIPE_PRICING_TABLE_ID=<NEXT_PUBLIC_STRIPE_PRICING_TABLE_ID>
STRIPE_SECRET_KEY=<STRIPE_SECRET_KEY>
STRIPE_PRICE_ID_MONTHLY=<STRIPE_PRICE_ID_MONTHLY>
STRIPE_PRICE_ID_YEARLY=<STRIPE_PRICE_ID_YEARLY>
STRIPE_WEBHOOK_SECRET=<STRIPE_WEBHOOK_SECRET>

# Shared secret used to verify GitHub and GitLab repository webhook deliveries.
# Generate with: openssl rand -hex 32
REPOSITORY_WEBHOOK_SECRET=<REPOSITORY_WEBHOOK_SECRET>
